{
  "name": "botdot",
  "version": "0.1.0",
  "description": "Asistente IA de compliance DOT/FMCSA para dispatchers, supervisores, compliance y managers (USDOT 2195271)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init-db": "node src/db/init.js",
    "migrate": "node src/db/migrate.js",
    "migrate:status": "node src/db/migrate.js --status",
    "ingest-sms": "node src/utils/ingest-sms.js",
    "verify-audit": "node scripts/verify-audit-chain.js",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "test": "node --test \"test/*.test.js\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.38.0",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "sharp": "^0.34.5"
  }
}
