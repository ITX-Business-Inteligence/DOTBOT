@page "/change-password"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory

@* Equivalente a public/change-password.html + public/js/change-password.js
   del Node. OnInit chequea sesion + must_change_password. Submit valida
   matching + length, POST /api/auth/change-password, redirige a /app.html. *@

<PageTitle>BOTDOT - Cambiar contraseña</PageTitle>

<main class="flex-1 flex items-center justify-center p-4">
    <div class="w-full max-w-md bg-slate-900 rounded-2xl shadow-2xl shadow-black/40 p-6 sm:p-8 border border-slate-800">
        <div class="text-center mb-5">
            <img src="/img/dotbot-header.png" alt="BOTDOT" class="w-14 h-14 rounded-xl mx-auto mb-3" />
            <h1 class="text-xl font-bold text-slate-100">Cambiar contraseña</h1>
            @if (mustChange)
            {
                <p class="text-xs text-amber-400 bg-amber-950/40 border border-amber-900/50 rounded p-2 mt-3">
                    Tu contraseña fue reseteada por un administrador. Necesitas elegir una nueva antes de continuar.
                </p>
            }
        </div>

        <EditForm Model="form" OnValidSubmit="HandleSubmitAsync" FormName="changeForm" class="space-y-3">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Contraseña actual</label>
                <InputText type="password" @bind-Value="form.Current" required
                    class="w-full px-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Nueva contraseña</label>
                <InputText type="password" @bind-Value="form.NewPass" required
                    class="w-full px-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500" />
                <p class="text-xs text-slate-500 mt-1">Mínimo 8 caracteres. Distinta a la actual.</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Confirmar nueva</label>
                <InputText type="password" @bind-Value="form.NewPass2" required
                    class="w-full px-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500" />
            </div>
            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="bg-red-950/60 border border-red-800 text-red-300 text-sm rounded-lg p-2">@errorMsg</div>
            }
            @if (!string.IsNullOrEmpty(successMsg))
            {
                <div class="bg-emerald-950/40 border border-emerald-900/60 text-emerald-200 text-sm rounded-lg p-2">@successMsg</div>
            }
            <button type="submit" disabled="@busy"
                class="w-full py-2.5 px-4 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold disabled:opacity-50">
                @(busy ? "Guardando..." : "Cambiar contraseña")
            </button>
            @if (!mustChange)
            {
                <p class="text-xs text-center text-slate-500">
                    <a href="/app.html" class="hover:text-slate-300">← Volver al chat</a>
                </p>
            }
        </EditForm>
    </div>
</main>
<footer class="text-center text-xs text-slate-500 p-4">USDOT 2195271 — BOTDOT</footer>

@code {
    private ChangeForm form = new();
    private string? errorMsg;
    private string? successMsg;
    private bool busy;
    private bool mustChange;

    public class ChangeForm
    {
        public string Current { get; set; } = "";
        public string NewPass { get; set; } = "";
        public string NewPass2 { get; set; } = "";
    }

    private class MeResponse
    {
        public UserPart? user { get; set; }
        public class UserPart
        {
            public bool must_change_password { get; set; }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Chequear sesion + must_change_password (matchea change-password.js init).
        try
        {
            var http = HttpFactory.CreateClient("self");
            http.BaseAddress ??= new Uri(Nav.BaseUri);
            var res = await http.GetAsync("/api/auth/me");
            if (!res.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/", forceLoad: true);
                return;
            }
            var me = await res.Content.ReadFromJsonAsync<MeResponse>();
            mustChange = me?.user?.must_change_password ?? false;
        }
        catch
        {
            Nav.NavigateTo("/", forceLoad: true);
        }
    }

    private async Task HandleSubmitAsync()
    {
        errorMsg = null;
        successMsg = null;
        if (form.NewPass != form.NewPass2)
        {
            errorMsg = "Las dos contraseñas nuevas no coinciden.";
            return;
        }
        if (form.NewPass.Length < 8)
        {
            errorMsg = "La nueva contraseña debe tener al menos 8 caracteres.";
            return;
        }
        busy = true;
        try
        {
            var http = HttpFactory.CreateClient("self");
            http.BaseAddress ??= new Uri(Nav.BaseUri);
            var res = await http.PostAsJsonAsync("/api/auth/change-password", new
            {
                current_password = form.Current,
                new_password = form.NewPass,
            });
            if (!res.IsSuccessStatusCode)
            {
                var body = await res.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMsg = body?.error ?? "Error cambiando password";
                return;
            }
            successMsg = "Contraseña cambiada. Redirigiendo al chat...";
            await Task.Delay(1200);
            Nav.NavigateTo("/app.html", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private class ErrorResponse
    {
        public string? error { get; set; }
    }
}
