# ========================================================
# BOTDOT - Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env al repo.
# ========================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# --- Base de datos MySQL (XAMPP local o VPS prod) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=botdot
DB_PASSWORD=cambiar_en_prod
DB_NAME=botdot

# --- Anthropic / Claude API ---
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXX
# Modelo principal del agente
CLAUDE_MODEL=claude-sonnet-4-6
# Modelo para tareas pesadas (analisis multi-BASIC, coaching notes)
CLAUDE_MODEL_HEAVY=claude-opus-4-7

# --- Samsara API ---
# Obtener en Samsara Dashboard > Settings > API Tokens (read-only en HOS, drivers, vehicles)
SAMSARA_API_TOKEN=samsara_api_XXXXXXXXXXXXXXX
SAMSARA_BASE_URL=https://api.samsara.com

# --- FMCSA SAFER (publico, no requiere key) ---
FMCSA_USDOT=2195271

# --- Auth ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_a_un_secreto_largo_aleatorio_min_64_chars
JWT_EXPIRES_IN=8h
COOKIE_SECRET=cambiar_a_otro_secreto_diferente

# --- Logging / Audit ---
LOG_LEVEL=info
AUDIT_RETENTION_DAYS=730
