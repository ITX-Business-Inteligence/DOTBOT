# ========================================================
# BOTDOT - Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env al repo.
# ========================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# --- Base de datos MySQL (XAMPP local o VPS prod) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=botdot
DB_PASSWORD=cambiar_en_prod
DB_NAME=botdot

# --- Anthropic / Claude API ---
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXX
# Modelo principal del agente
CLAUDE_MODEL=claude-sonnet-4-6
# Modelo para tareas pesadas (analisis multi-BASIC, coaching notes)
CLAUDE_MODEL_HEAVY=claude-opus-4-7
# MOCK LLM — true en dev, false en prod. Si true, no llama a Claude real.
# Las API keys reales viven SOLO en el server de produccion por seguridad.
BOTDOT_MOCK_LLM=true

# --- Samsara API ---
# Obtener en Samsara Dashboard > Settings > API Tokens (read-only en HOS, drivers, vehicles)
SAMSARA_API_TOKEN=samsara_api_XXXXXXXXXXXXXXX
SAMSARA_BASE_URL=https://api.samsara.com
# MOCK SAMSARA — true en dev, false en prod. Si true, drivers/vehicles/HOS
# vienen de fixtures (src/integrations/samsara-mock.js).
BOTDOT_MOCK_SAMSARA=true

# --- Sync scheduler (background jobs) ---
# Si =false, el scheduler no arranca. En dev no es necesario apagarlo.
BOTDOT_SYNC_ENABLED=true
# Frecuencias (minutos). Drivers/vehicles cambian poco; HOS clocks mucho.
BOTDOT_SYNC_DRIVERS_MIN=60
BOTDOT_SYNC_VEHICLES_MIN=60
BOTDOT_SYNC_HOS_MIN=5

# --- FMCSA SAFER (publico, no requiere key) ---
FMCSA_USDOT=2195271

# --- Auth ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_a_un_secreto_largo_aleatorio_min_64_chars
JWT_EXPIRES_IN=8h
COOKIE_SECRET=cambiar_a_otro_secreto_diferente

# --- Logging / Audit ---
LOG_LEVEL=info
AUDIT_RETENTION_DAYS=730

# --- Chat budget caps & rate limit ---
# Cap diario por usuario en USD (ventana 24h rolling). 0 desactiva.
BOTDOT_USER_DAILY_BUDGET_USD=5
# Cap diario organizacional en USD (ventana 24h rolling). 0 desactiva.
BOTDOT_ORG_DAILY_BUDGET_USD=25
# Rate limit en /api/chat/send por usuario autenticado (req/min). 0 desactiva.
BOTDOT_CHAT_RATE_LIMIT_PER_MIN=30

# --- Backups (lee scripts/backup.sh) ---
# Carpeta local donde se guardan dumps + manifests
BOTDOT_BACKUP_DIR=/home/botdot/botdot-backups
# Cuantos dias mantener locales antes de borrar
BOTDOT_BACKUP_RETENTION_DAYS=30
# Si quieres subir a S3/R2/B2, completar las 3 siguientes (sino dejar vacias).
# Para AWS S3: solo BOTDOT_S3_BUCKET (mas credenciales en ~/.aws/credentials).
# Para Cloudflare R2: setea BOTDOT_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# Para Backblaze B2: setea BOTDOT_S3_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
BOTDOT_S3_BUCKET=
BOTDOT_S3_PREFIX=botdot
BOTDOT_S3_ENDPOINT_URL=
